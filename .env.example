# ── BudgetKatta environment ──────────────────────────────
# Copy this file to .env.local and fill in values.
# Everything is OPTIONAL for local dev — the app runs with sample data,
# a rule-based chatbot, an animated fallback bot, console-logged leads,
# and "coming soon" voice when these are left blank.

# ── Database ────────────────────────────────────────────
# MongoDB Atlas connection string (server-side only — keep secret).
# When set, run `npm run seed` to load demo data; the site then serves DB data.
MONGODB_URI=

# ── n8n lead automation ─────────────────────────────────
# Server-side webhook used by /api/leads (preferred — kept out of the browser).
N8N_WEBHOOK_URL=
# Public webhook used by lightweight client events (e.g. bot quick actions).
# If N8N_WEBHOOK_URL is unset, /api/leads falls back to this one.
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# ── Gemini chatbot ──────────────────────────────────────
# Google Gemini API key (server-side only — keep secret).
# When unset, the bot uses a rule-based finance fallback.
GEMINI_API_KEY=

# ── Vapi voice assistant ────────────────────────────────
# Must be NEXT_PUBLIC_ so the client can detect it and start a call.
# When unset, the voice button shows a bilingual "coming soon" message.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# ── Spline 3D robot ─────────────────────────────────────
# Scene URL for the desktop bot, e.g.
# https://prod.spline.design/XXXXXXXX/scene.splinecode
# When unset, a premium animated fallback robot is shown.
NEXT_PUBLIC_SPLINE_SCENE_URL=

# ── Contact ─────────────────────────────────────────────
# Public contact email shown across the site. Falls back to hello@budgetkatta.in.
NEXT_PUBLIC_CONTACT_EMAIL=hello@budgetkatta.in

# ── Contact / WhatsApp ──────────────────────────────────
# WhatsApp number in international format without "+" (e.g. 919876543210).
# When set, the Contact page shows a WhatsApp CTA; otherwise "coming soon".
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Admin placeholder ───────────────────────────────────
# Set to "true" to enable the /admin overview page.
NEXT_PUBLIC_ENABLE_ADMIN=

# ── Affiliate links ─────────────────────────────────────
# Real referral / affiliate URLs for the promo banners. When unset, the banner
# shows a disabled "Coming soon" CTA instead of a dead link.
NEXT_PUBLIC_AFF_DEMAT=
NEXT_PUBLIC_AFF_CREDIT_CARD=
NEXT_PUBLIC_AFF_LOAN=
NEXT_PUBLIC_AFF_INSURANCE=
# Amazon Associates tracking tag (e.g. budgetkatta-21). Appended to amazon.in
# product URLs via withAmazonTag(). Required to earn Amazon commissions.
NEXT_PUBLIC_AMAZON_TAG=
# Broker referral links for the "Demat & Investing App Offers" section.
# When unset, the card links to the broker's official site.
NEXT_PUBLIC_AFF_ZERODHA=
NEXT_PUBLIC_AFF_UPSTOX=
NEXT_PUBLIC_AFF_ANGELONE=
NEXT_PUBLIC_AFF_GROWW=

# ── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
